<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_kai_view" model="ir.module.category">
        <field name="name">kaiSight</field>
        <field name="description">Dashboards and saved reports</field>
        <field name="sequence">25</field>
    </record>

    <record id="privilege_kai_view" model="res.groups.privilege">
        <field name="name">kaiSight</field>
        <field name="sequence">25</field>
        <field name="category_id" ref="module_category_kai_view"/>
    </record>

    <record id="group_kai_view_user" model="res.groups">
        <field name="name">User</field>
        <field name="sequence">10</field>
        <field name="privilege_id" ref="privilege_kai_view"/>
        <field name="implied_by_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_kai_view_manager" model="res.groups">
        <field name="name">Administrator</field>
        <field name="sequence">20</field>
        <field name="privilege_id" ref="privilege_kai_view"/>
        <field name="implied_ids" eval="[(4, ref('group_kai_view_user'))]"/>
        <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>

    <record id="rule_dashboard_user" model="ir.rule">
        <field name="name">kaiSight dashboard: own or shared</field>
        <field name="model_id" ref="model_kai_view_dashboard"/>
        <field name="domain_force">['|', ('is_shared', '=', True), ('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_kai_view_user'))]"/>
    </record>

    <record id="rule_report_user" model="ir.rule">
        <field name="name">kaiSight report: own or shared</field>
        <field name="model_id" ref="model_kai_view_report"/>
        <field name="domain_force">['|', ('is_shared', '=', True), ('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_kai_view_user'))]"/>
    </record>

    <record id="rule_dashboard_manager" model="ir.rule">
        <field name="name">kaiSight dashboard: administrator all</field>
        <field name="model_id" ref="model_kai_view_dashboard"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_kai_view_manager'))]"/>
    </record>

    <record id="rule_report_manager" model="ir.rule">
        <field name="name">kaiSight report: administrator all</field>
        <field name="model_id" ref="model_kai_view_report"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_kai_view_manager'))]"/>
    </record>
</odoo>
