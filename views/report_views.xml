<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_kai_view_report_list" model="ir.ui.view">
        <field name="name">kai.view.report.list</field>
        <field name="model">kai.view.report</field>
        <field name="arch" type="xml">
            <list class="o_kai_saved_reports_list"
                  string="Saved Reports"
                  default_order="sequence, name">
                <field name="sequence" widget="handle" optional="hide"/>
                <!-- Click the name (row) to edit the saved report definition. -->
                <field name="name" string="Report"/>
                <field name="description" optional="show"/>
                <field name="model_id" string="Data"/>
                <field name="is_shared" optional="hide"/>
                <field name="active" column_invisible="True"/>
                <!-- Open = live Odoo list/form of the report's filtered records. -->
                <button name="action_open_report"
                        type="object"
                        string="Open"
                        class="btn btn-primary"
                        icon="fa-external-link"
                        title="Open the filtered records in Odoo"/>
                <button name="action_export_xlsx"
                        type="object"
                        string="Excel"
                        class="btn btn-secondary"
                        icon="fa-file-excel-o"/>
                <button name="action_export_pdf"
                        type="object"
                        string="PDF"
                        class="btn btn-secondary"
                        icon="fa-file-pdf-o"/>
                <button name="action_schedule_report"
                        type="object"
                        string="Schedule"
                        class="btn btn-secondary"
                        icon="fa-clock-o"
                        title="Schedule automatic Excel / export delivery"/>
            </list>
        </field>
    </record>

    <record id="view_kai_view_report_form" model="ir.ui.view">
        <field name="name">kai.view.report.form</field>
        <field name="model">kai.view.report</field>
        <field name="arch" type="xml">
            <form string="Saved report">
                <header>
                    <button name="action_open_report" type="object" string="Run report" class="btn-primary"/>
                    <button name="action_export_xlsx" type="object" string="Export Excel"/>
                    <button name="action_export_pdf" type="object" string="Export PDF"/>
                    <button name="action_schedule_report" type="object" string="Schedule"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Report name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="model_id"/>
                            <field name="view_mode"/>
                            <field name="user_id" invisible="1"/>
                        </group>
                        <group>
                            <field name="is_shared"/>
                            <field name="active"/>
                            <field name="sequence"/>
                        </group>
                    </group>
                    <field name="description" placeholder="Short description (optional)"/>
                    <field name="model_name" invisible="1"/>
                    <field name="res_model_name" invisible="1"/>
                    <notebook>
                        <page string="Data" name="data">
                            <group>
                                <p class="text-muted" colspan="2">
                                    Select a model first. Filters must use fields from that model only.
                                </p>
                                <field name="domain" widget="domain" options="{'model': 'res_model_name', 'in_dialog': True}" readonly="not model_id"/>
                            </group>
                            <group string="Columns" invisible="not model_id">
                                <field name="field_ids" nolabel="1" colspan="2">
                                    <list editable="bottom">
                                        <field name="sequence" widget="handle"/>
                                        <field name="field_id"/>
                                    </list>
                                </field>
                            </group>
                            <p class="text-muted" invisible="not model_id">
                                Choose which fields appear in the list view. Leave empty to use the model’s default list view.
                            </p>
                        </page>
                        <page string="Advanced" name="advanced">
                            <group>
                                <field name="context" widget="text" placeholder="{'search_default_my': 1}"/>
                            </group>
                            <field name="list_view_id" groups="base.group_no_one"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_kai_view_reports" model="ir.actions.act_window">
        <field name="name">Saved Reports</field>
        <field name="res_model">kai.view.report</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No saved reports yet
            </p>
            <p>
                Open Data Export to build a report, then save it here for one-click access.
            </p>
        </field>
    </record>
</odoo>
