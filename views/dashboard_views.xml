<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_kai_view_dashboard_list" model="ir.ui.view">
        <field name="name">kai.view.dashboard.list</field>
        <field name="model">kai.view.dashboard</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="user_id" widget="many2one_avatar_user"/>
                <field name="widget_count"/>
                <field name="is_shared"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="active" column_invisible="True"/>
            </list>
        </field>
    </record>

    <record id="view_kai_view_dashboard_form" model="ir.ui.view">
        <field name="name">kai.view.dashboard.form</field>
        <field name="model">kai.view.dashboard</field>
        <field name="arch" type="xml">
            <form string="Dashboard">
                <header>
                    <button name="action_open_dashboard" type="object" string="Open" class="btn-primary"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_dashboard" type="object" class="oe_stat_button" icon="fa-tachometer">
                            <field name="widget_count" widget="statinfo" string="Widgets"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="user_id" groups="kaisight.group_kai_view_manager"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="is_shared"/>
                            <field name="active"/>
                            <field name="sequence"/>
                        </group>
                    </group>
                    <field name="description" placeholder="What this dashboard is for..."/>
                    <notebook>
                        <page string="Widgets" name="widgets">
                            <p class="text-muted mb-2">
                                Add a widget, then open its row to configure filters, measures, and columns.
                            </p>
                            <field name="widget_ids" context="{'default_dashboard_id': id}">
                                <list>
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="widget_type"/>
                                    <field name="model_id"/>
                                    <field name="aggregate" optional="show"/>
                                    <field name="grid_column"/>
                                    <field name="grid_width"/>
                                    <field name="active" column_invisible="True"/>
                                </list>
                                <form string="Widget">
                                    <sheet>
                                        <group>
                                            <group string="General">
                                                <field name="name"/>
                                                <field name="widget_type"/>
                                            <field name="model_id"/>
                                            <field name="model_name" invisible="1"/>
                                            <field name="res_model_name" invisible="1"/>
                                            <field name="active"/>
                                                <field name="sequence"/>
                                            </group>
                                            <group string="Layout">
                                                <field name="grid_column"/>
                                                <field name="grid_width"/>
                                                <field name="color_index"/>
                                            </group>
                                        </group>
                                        <group string="Data source" invisible="not model_id">
                                            <p class="text-muted" colspan="2">
                                                Pick the model above first, then define which records are included.
                                                Use only fields that exist on that model (e.g. avoid “active” if the model has no such field).
                                            </p>
                                            <field name="domain" widget="domain" options="{'model': 'res_model_name', 'in_dialog': True}" nolabel="1" colspan="2"/>
                                        </group>
                                        <group string="KPI options" invisible="widget_type != 'kpi'">
                                            <field name="icon"/>
                                            <field name="subtitle"/>
                                            <field name="aggregate"/>
                                            <field name="measure_field_id" invisible="aggregate == 'count'"/>
                                            <field name="measure_field" invisible="1"/>
                                        </group>
                                        <group string="Chart options" invisible="widget_type != 'chart'">
                                            <field name="chart_type"/>
                                            <field name="groupby_field_id"/>
                                            <field name="groupby_field" invisible="1"/>
                                            <field name="aggregate"/>
                                            <field name="measure_field_id" invisible="aggregate == 'count'"/>
                                            <field name="measure_field" invisible="1"/>
                                        </group>
                                        <group string="List options" invisible="widget_type != 'list'">
                                            <field name="list_field_ids" widget="many2many_tags" options="{'no_create': True}"/>
                                            <field name="list_fields" invisible="1"/>
                                            <field name="record_limit"/>
                                        </group>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_kai_view_widget_form" model="ir.ui.view">
        <field name="name">kai.view.widget.form</field>
        <field name="model">kai.view.widget</field>
        <field name="arch" type="xml">
            <form string="Widget">
                <sheet>
                    <group>
                        <group>
                            <field name="dashboard_id"/>
                            <field name="name"/>
                            <field name="widget_type"/>
                            <field name="model_id"/>
                            <field name="model_name" invisible="1"/>
                            <field name="res_model_name" invisible="1"/>
                        </group>
                        <group>
                            <field name="grid_column"/>
                            <field name="grid_width"/>
                            <field name="sequence"/>
                        </group>
                    </group>
                    <group string="Filter" invisible="not model_id">
                        <field name="domain" widget="domain" options="{'model': 'res_model_name', 'in_dialog': True}" nolabel="1" colspan="2"/>
                    </group>
                    <group string="KPI" invisible="widget_type != 'kpi'">
                        <field name="icon"/>
                        <field name="subtitle"/>
                        <field name="aggregate"/>
                        <field name="measure_field_id" invisible="aggregate == 'count'"/>
                    </group>
                    <group string="Chart" invisible="widget_type != 'chart'">
                        <field name="chart_type"/>
                        <field name="groupby_field_id"/>
                        <field name="aggregate"/>
                        <field name="measure_field_id" invisible="aggregate == 'count'"/>
                    </group>
                    <group string="List" invisible="widget_type != 'list'">
                        <field name="list_field_ids" widget="many2many_tags" options="{'no_create': True}"/>
                        <field name="record_limit"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_kai_view_dashboards" model="ir.actions.act_window">
        <field name="name">Dashboards</field>
        <field name="res_model">kai.view.dashboard</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a dashboard
            </p>
            <p>
                Add widgets that query any model from your installed addons, then open the dashboard in interactive mode.
            </p>
        </field>
    </record>

    <record id="action_kai_view_dashboard_client" model="ir.actions.client">
        <field name="name">kaisight</field>
        <field name="tag">kai_view_dashboard</field>
    </record>
</odoo>
