<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_kai_view_report_source_list" model="ir.ui.view">
        <field name="name">kai.view.report.source.list</field>
        <field name="model">kai.view.report.source</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="model_id"/>
                <field name="icon"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_kai_view_report_source_form" model="ir.ui.view">
        <field name="name">kai.view.report.source.form</field>
        <field name="model">kai.view.report.source</field>
        <field name="arch" type="xml">
            <form string="Data source">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="model_id"/>
                            <field name="icon"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="active"/>
                            <field name="group_ids" widget="many2many_tags"/>
                        </group>
                    </group>
                    <field name="description" placeholder="Short help text shown in the report builder…"/>
                    <group string="Recommended columns">
                        <field name="default_field_ids" widget="many2many_tags" nolabel="1" colspan="2"
                            options="{'no_create': True}"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_kai_view_report_sources" model="ir.actions.act_window">
        <field name="name">Data sources</field>
        <field name="res_model">kai.view.report.source</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Register a data source
            </p>
            <p>
                Each source appears as a card in the Report Builder. Other addons can add school-specific tables here.
            </p>
        </field>
    </record>

    <record id="view_kai_view_report_builder_filter_form" model="ir.ui.view">
        <field name="name">kai.view.report.builder.filter.form</field>
        <field name="model">kai.view.report.builder</field>
        <field name="arch" type="xml">
            <form string="Report filters">
                <group>
                    <field name="model_id" invisible="1"/>
                    <field name="res_model_name" invisible="1"/>
                    <field name="domain" widget="domain" options="{'model': 'res_model_name', 'in_dialog': False}" nolabel="1" colspan="2"/>
                </group>
                <footer>
                    <button string="Apply" class="btn-primary" special="save"/>
                    <button string="Cancel" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="view_kai_view_report_builder_save_form" model="ir.ui.view">
        <field name="name">kai.view.report.builder.save.form</field>
        <field name="model">kai.view.report.builder</field>
        <field name="arch" type="xml">
            <form string="Save report">
                <group>
                    <field name="name" placeholder="e.g. Active students — contact list"/>
                    <field name="is_shared"/>
                    <field name="model_id" invisible="1"/>
                </group>
                <footer>
                    <button string="Save" class="btn-primary" special="save"/>
                    <button string="Cancel" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_kai_view_report_builder_client" model="ir.actions.client">
        <field name="name">Report Builder</field>
        <field name="tag">kai_view_report_builder</field>
    </record>
</odoo>
